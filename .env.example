# ── Google Cloud ──────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ── Retrieval backend: "none" | "rag_store" | "vertex_search" | "vector_search"
# "none" = direct Gemini chat (uses system prompt from PocketBase config)
DEFAULT_RETRIEVAL_BACKEND=none

# ── Vertex RAG Store ─────────────────────────────────────────
RAG_CORPUS_NAME=projects/{project}/locations/{location}/ragCorpora/{corpus_id}

# ── Vertex AI Search ─────────────────────────────────────────
VERTEX_SEARCH_DATASTORE=projects/{project}/locations/{location}/collections/default_collection/dataStores/{datastore_id}
VERTEX_SEARCH_SERVING_CONFIG=projects/{project}/locations/{location}/collections/default_collection/dataStores/{datastore_id}/servingConfigs/default_serving_config

# ── Vector Search (Matching Engine) ──────────────────────────
VECTOR_SEARCH_INDEX_ENDPOINT=projects/{project}/locations/{location}/indexEndpoints/{endpoint_id}
VECTOR_SEARCH_DEPLOYED_INDEX_ID=your_deployed_index_id
EMBEDDING_MODEL=text-embedding-005

# ── Vertex AI LLM ────────────────────────────────────────────
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_MAX_OUTPUT_TOKENS=2048

# ── PocketBase ───────────────────────────────────────────────
POCKETBASE_URL=http://pocketbase:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=change-me-in-production

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
LOG_LEVEL=info

# ── Content Moderation ────────────────────────────────────────
MODERATION_ENABLED=true
MODERATION_CUSTOM_BLOCKED=

# ── Caddy ────────────────────────────────────────────────────
DOMAIN=localhost

# ── Branding (customize per clone) ───────────────────────────
BOT_NAME=Chat Assistant
BOT_ICON_URL=
WELCOME_TITLE=How can I help you?
WELCOME_SUBTITLE=Ask me anything.
POWERED_BY_TEXT=

# ── Error email notifications ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
ERROR_NOTIFY_EMAILS=
