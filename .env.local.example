# ── Minimal .env for localhost testing (no GCP needed) ───────
# Copy to .env and edit.

# Leave blank to skip GCP init — direct Gemini mode still requires a project
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# "none" = direct Gemini chat (no retrieval). Set system prompt in PocketBase.
DEFAULT_RETRIEVAL_BACKEND=none

# ── Vertex AI LLM ────────────────────────────────────────────
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_MAX_OUTPUT_TOKENS=2048

# ── PocketBase (localhost) ───────────────────────────────────
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=change-me

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=debug

DOMAIN=localhost
